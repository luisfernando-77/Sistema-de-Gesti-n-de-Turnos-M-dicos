generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/* ======================
   PACIENTES
====================== */

model Paciente {
  id        Int     @id @default(autoincrement())
  nombre    String
  correo    String  @unique
  telefono  String?
  turnos    Turno[]
}

/* ======================
   ESPECIALIDADES
====================== */

model Especialidad {
  id       Int      @id @default(autoincrement())
  nombre   String   @unique
  medicos  Medico[]
}

/* ======================
   MEDICOS
====================== */

model Medico {
  id              Int            @id @default(autoincrement())
  nombre          String
  correo          String         @unique
  especialidadId  Int
  especialidad    Especialidad   @relation(fields: [especialidadId], references: [id])
  turnos          Turno[]
}

/* ======================
   CONSULTORIOS
====================== */

model Consultorio {
  id       Int     @id @default(autoincrement())
  nombre   String
  ubicacion String
  turnos   Turno[]
}

/* ======================
   TURNOS MEDICOS
====================== */

model Turno {
  id             Int          @id @default(autoincrement())
  fecha          DateTime
  estado         EstadoTurno  @default(PENDIENTE)

  pacienteId     Int
  paciente       Paciente     @relation(fields: [pacienteId], references: [id])

  medicoId       Int
  medico         Medico       @relation(fields: [medicoId], references: [id])

  consultorioId  Int
  consultorio    Consultorio  @relation(fields: [consultorioId], references: [id])
}

/* ======================
   ENUMS
====================== */

enum EstadoTurno {
  PENDIENTE
  CONFIRMADO
  CANCELADO
  COMPLETADO
}