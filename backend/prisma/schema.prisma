// ============================================================
// ESQUEMA DE BASE DE DATOS — SISTEMA DE TURNOS MÉDICOS
// ============================================================
//
// Prisma usa este archivo para:
//   1. Crear tablas y migraciones
//   2. Generar Prisma Client
//   3. Validar relaciones y consultas
//
// DIAGRAMA GENERAL:
//
// Especialidad ──1:N──> Medico
// Paciente ──1:N──> Turno
// Medico ──1:N──> Turno
// Consultorio ──1:N──> Turno
//
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// PACIENTES
// Representa un paciente del sistema médico.
// Puede tener MUCHOS turnos.
// ============================================================

model Paciente {
  id        Int      @id @default(autoincrement())
  nombre    String
  correo    String   @unique
  telefono  String?

  turnos    Turno[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pacientes")
}

// ============================================================
// ESPECIALIDADES MÉDICAS
// Ej: Pediatría, Cardiología, Dermatología
// Una especialidad puede tener MUCHOS médicos.
// ============================================================

model Especialidad {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique

  medicos   Medico[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("especialidades")
}

// ============================================================
// MÉDICOS
// Pertenece a UNA especialidad.
// Puede atender MUCHOS turnos.
// ============================================================

model Medico {
  id              Int            @id @default(autoincrement())
  nombre          String
  correo          String         @unique

  especialidadId  Int
  especialidad    Especialidad   @relation(fields: [especialidadId], references: [id])

  turnos          Turno[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("medicos")
}

// ============================================================
// CONSULTORIOS
// Lugar físico donde se atienden los pacientes.
// ============================================================

model Consultorio {
  id         Int      @id @default(autoincrement())
  nombre     String
  ubicacion  String

  turnos     Turno[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("consultorios")
}

// ============================================================
// TURNOS MÉDICOS
// Relaciona:
//   Paciente + Médico + Consultorio + Fecha
// ============================================================

model Turno {
  id             Int          @id @default(autoincrement())
  fecha          DateTime
  estado         EstadoTurno  @default(PENDIENTE)

  pacienteId     Int
  paciente       Paciente     @relation(fields: [pacienteId], references: [id])

  medicoId       Int
  medico         Medico       @relation(fields: [medicoId], references: [id])

  consultorioId  Int
  consultorio    Consultorio  @relation(fields: [consultorioId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("turnos")
}

// ============================================================
// ENUMS
// Estados posibles de un turno médico
// ============================================================

enum EstadoTurno {
  PENDIENTE
  CONFIRMADO
  CANCELADO
  COMPLETADO
}